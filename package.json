{
	"name": "billbot",
	"description": "Telegram bot for work tracking and invoicing on Cloudflare Workers.",
	"private": true,
	"dependencies": {
		"grammy": "^1.35.0",
		"hono": "4.12.14"
	},
	"devDependencies": {
		"@types/node": "24.10.1",
		"typescript": "5.9.3",
		"vitest": "3.2.4",
		"wrangler": "4.80.0"
	},
	"overrides": {
		"picomatch": "4.0.4",
		"rollup": "4.60.1"
	},
	"scripts": {
		"cf-typegen": "wrangler types",
		"deploy": "wrangler deploy",
		"dev": "wrangler dev",
		"predeploy": "wrangler d1 migrations apply DB --remote",
		"migrate:local": "wrangler d1 migrations apply DB --local",
		"test": "wrangler deploy --dry-run",
		"test:integration": "vitest run tests/integration/bot.test.ts --environment node"
	}
}
